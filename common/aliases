# Directory change shortcuts
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

# Most used commands
alias grep='grep --color'
alias ll='ls -ltra'
alias ls='ls -F --color'
alias h='history'
alias vi='vim'

# Process related
alias psall='ps -auxww '
alias ppid='ps -o ppid= -p '

# Git related
alias gs='git status'
alias gl='git log'
alias gln='git --no-pager log -n '
alias gco='git checkout'
alias ga='git add'
alias gaa='git add -A'
alias gau='git add -u'
alias gc='git commit'
alias gcm='git commit -m'

# Git Analysis
alias gd='git diff'

# Git modifications
alias greb='git rebase -i'

# Github
alias gp='git pull'

# Find and edit a file with fzf
fe() {
  local file
  file=$(find . -type f | fzf --height 40%)
  if [[ -n $file ]]; then
    nvim "$file"
  fi
}
